# ─── Database ────────────────────────────────────────────────────────────────
# Local dev:  sqlite:///./data/app.db
# Server:     postgresql://user:pass@db:5432/statements
DATABASE_URL=sqlite:///./data/app.db

# ─── LLM Categorizer ─────────────────────────────────────────────────────────
# Options: ollama | claude | none
# - ollama: fully offline, requires Ollama installed (https://ollama.com)
# - claude: requires ANTHROPIC_API_KEY and internet connection
# - none:   rule-engine only, no LLM fallback
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
ANTHROPIC_API_KEY=

# ─── File Storage ────────────────────────────────────────────────────────────
# Options: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/uploads
# S3 / Cloudflare R2 (only needed if STORAGE_BACKEND=s3):
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── API / CORS ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local:  http://localhost:5173
# Network: http://192.168.x.x:5173
# Server: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Must match the backend URL the browser can reach
VITE_API_URL=http://localhost:8000
